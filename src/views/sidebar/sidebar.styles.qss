.sidebar {
    background-color: blue;
    max-width: 60px;
    margin: 0;
    background-color: rgb(0, 145, 255);
}

.button{
    margin: 0;
    padding: 0;
    width: 100%;
    height: 60px;
    font-size: 20px;
    border-radius: 0px;
    border: 0px;
    color: whilte;
}
.button.activated{
    background-color: rgb(17, 113, 217);
}
