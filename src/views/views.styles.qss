
#view {
    background-color: #C5C5C5;
    padding: 0;
    margin: 0;
}
.sidebar {
    background-color: blue;
    max-width: 60px;
    margin: 0;
}
.page {
    background-color: green;
}
.button{
    margin: 0;
    padding: 0;
    width: 100%;
    height: 40px;
    border-radius: None;
    border: 1px solid black;
}

.btn-store:pressed{
    background: yellow;
}
.btn-robot:pressed{
    background: green;
}